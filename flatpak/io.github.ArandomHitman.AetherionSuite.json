{
    "app-id": "io.github.ArandomHitman.AetherionSuite",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.8",
    "sdk": "org.kde.Sdk//6.8",
    "command": "blackhole-sim",

    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--filesystem=home"
    ],

    "modules": [
        {
            "name": "glew",
            "buildsystem": "simple",
            "build-commands": [
                "make GLEW_NO_GLU=1 STRIP= CFLAGS.EXTRA=-fPIC",
                "make install GLEW_NO_GLU=1 GLEW_DEST=/app LIBDIR=/app/lib"
            ],
            "cleanup": [
                "/include",
                "/lib/pkgconfig",
                "/lib/*.a"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/nigels-com/glew/releases/download/glew-2.2.0/glew-2.2.0.tgz",
                    "sha256": "d4fc82893cfb00109578d0a1a2337fb8ca335b3ceccf97b97e5cc7f08e4353e1"
                }
            ]
        },

        {
            "name": "glm",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DGLM_BUILD_TESTS=OFF",
                "-DBUILD_SHARED_LIBS=OFF"
            ],
            "cleanup": [
                "/include",
                "/lib/cmake",
                "/lib/pkgconfig"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/g-truc/glm/archive/refs/tags/1.0.1.tar.gz",
                    "sha256": "9f3174561fd26904b23f0db5e560971cbf9b3cbda0b280f04d5c379d03bf234c"
                }
            ]
        },

        {
            "name": "sfml",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DSFML_BUILD_AUDIO=OFF",
                "-DSFML_BUILD_NETWORK=OFF",
                "-DSFML_BUILD_TEST_SUITE=OFF",
                "-DSFML_BUILD_EXAMPLES=OFF",
                "-DSFML_BUILD_DOC=OFF",
                "-DBUILD_SHARED_LIBS=ON",
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_INSTALL_LIBDIR=lib"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/SFML/SFML/archive/refs/tags/3.0.0.tar.gz",
                    "sha256": "37506fafbd618b1f8e153bbca8811e62203a70b32a1183279fb9612fd0501d2b"
                }
            ]
        },

        {
            "name": "aetherionsuite",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=Release",
                "-DCMAKE_CXX_FLAGS=-DGLEW_NO_GLU"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": ".."
                }
            ]
        }
    ]
}
